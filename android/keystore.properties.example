# REQUIRED for Play Store uploads (without this file, bundleRelease will fail — no more accidental debug AABs).
#
# Copy this file to: android/keystore.properties
# Put upload-keystore.jks in the android/ folder (same folder as this file’s copy).
# Never commit keystore.properties or *.jks to git.
#
# 1) Create upload keystore (once), from repo android/ folder:
#    cd android
#    keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# 2) Copy and edit:
#    copy keystore.properties.example keystore.properties
#
# 3) Fill real passwords below (match what you typed for keytool).
#
# 4) Build:
#    cd ..
#    npm run build && npx cap sync android && cd android && gradlew.bat bundleRelease
#
# 5) Optional: scripts\verify-play-bundle-signing.cmd — should NOT show "Android Debug".

storePassword=YOUR_KEYSTORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=upload
storeFile=upload-keystore.jks
